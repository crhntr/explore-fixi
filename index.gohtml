<!DOCTYPE html>
<html lang='us-en'>
<head>
	<meta charset="UTF-8">
	<title>Explore Fixi</title>
	<meta name="description" content="Exploring using Fixi with Go">
	<script src="https://cdn.jsdelivr.net/npm/the-fixi-project@0.1.1/dist/the-fixi-project.min.js" integrity="sha256-aQhU79uUGCZTYXEtsijzqKVynikd1uZqOfGAovLVYOU=" crossorigin="anonymous"></script>
</head>
<body>
	<button fx-action='{{.Path.Count}}' fx-target='#greeting' fx-swap='innerHTML'>Increment</button>
	<p id='greeting' fx-action='{{.Path.Updates}}' fx-trigger='fx:inited' fx-swap='innerHTML'>{{template "hello" .Result}}</p>
</body>
</html>

{{define "hello"}}{{.}}{{end}}

{{define "GET /count Count()"}}{{template "hello" .Result}}{{end}}

{{define "GET /{$} Index()"}}{{template "index.gohtml" .}}{{end}}