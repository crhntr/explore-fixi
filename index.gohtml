<!DOCTYPE html>
<html lang='us-en'>
<head>
	<meta charset="UTF-8">
	<title>Explore Fixi</title>
	<meta name="description" content="Exploring using Fixi with Go">
	<script src="https://cdn.jsdelivr.net/npm/the-fixi-project@0.1.1/dist/the-fixi-project.min.js" integrity="sha256-aQhU79uUGCZTYXEtsijzqKVynikd1uZqOfGAovLVYOU=" crossorigin="anonymous"></script>
</head>
<body>
	<button
					fx-action='{{.Path.Count}}'
					fx-target='#greeting'
					fx-swap='innerHTML'
	>Click Me</button>
	<p id='greeting'>Hello!</p>
	<ul fx-trigger="fx:inited" fx-action="/feed" fx-swap="beforeend"></ul>
</body>
</html>

{{define "history-entree" -}}<li>{{.}}</li>{{end}}

{{define "GET /count Count()" -}}Hello, world! n={{.Result}}{{- end}}

{{define "GET /{$}" -}}{{template "index.gohtml" .}}{{- end}}